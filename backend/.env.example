# Backend Environment Variables Template
# Copy file này thành .env và điền giá trị thật

# Database
DB_HOST=your-db-host.onrender.com
DB_PORT=5432
DB_NAME=seveneleven
DB_USERNAME=postgres
DB_PASSWORD=your-db-password

# Redis (disable for free tier)
REDIS_ENABLED=false
CACHE_TYPE=simple

# JWT - THAY ĐỔI GIÁ TRỊ NÀY!
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-characters

# CORS - Danh sách origin được phép (phân cách bằng dấu phẩy)
CORS_ORIGINS=https://your-frontend.netlify.app,https://7-eleven-test.vercel.app,http://localhost:5173

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# Logging
LOGGING_LEVEL_COM_SEVENELEVEN=INFO
